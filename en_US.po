#: 201R63
msgctxt "201R63"
msgid "Thanks, Qian Shu."
msgstr "Thanks, Qian Shu."

#: 201RXX
msgctxt "201RXX"
msgid "Brain, brain, brain, brain."
msgstr "Brain, brain, brain, brain."

#: 201X01
msgctxt "201X01"
msgid "Hello, Mr Ripley. Welcome back. Hello, Mei Chen. It is nice seeing you both back."
msgstr "Hello, Mr Ripley. Welcome back. Hello, Mei Chen. It is nice seeing you both back."

#: 201X02
msgctxt "201X02"
msgid "I'm saddened to say no."
msgstr "I'm saddened to say no."

#: 201X03
msgctxt "201X03"
msgid "Ni hao, Mr. Ripley."
msgstr "Ni hao, Mr. Ripley."

#: 201X04
msgctxt "201X04"
msgid "There is a message for you."
msgstr "There is a message for you."

#: 201X05
