msgid "The sixth in a row of seven soldiers wearing yellow skirts."
msgstr "The sixth in a row of seven soldiers wearing yellow skirts."

#: 824R08
msgctxt "824R08"
msgid "The seventh in a row of seven soldiers wearing yellow skirts."
msgstr "The seventh in a row of seven soldiers wearing yellow skirts."

#: 824R11
msgctxt "824R11"
msgid "The weight of Mount Li has taken a toll on the ceiling of this corridor."
msgstr "The weight of Mount Li has taken a toll on the ceiling of this corridor."

#: 824R14
msgctxt "824R14"
msgid "One of the terracotta horses in this corridor has been damaged."
msgstr "One of the terracotta horses in this corridor has been damaged."

#: 824R17
