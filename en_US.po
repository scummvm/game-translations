msgid "Ripley, keep your hands off!"
msgstr "Ripley, keep your hands off!"

#: 201R57
msgctxt "201R57"
msgid "There's no time."
msgstr "There's no time."

#: 201R58
msgctxt "201R58"
msgid "I'm not thinking."
msgstr "I'm not thinking."

#: 201R59
msgctxt "201R59"
msgid "That will work."
msgstr "That will work."

#: 201R60
msgctxt "201R60"
msgid "Mei Chen has an aunt and uncle in London. I want to send them a radiogram."
msgstr "Mei Chen has an aunt and uncle in London. I want to send them a radiogram."

#: 201R61
