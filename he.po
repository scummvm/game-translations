msgstr "HERO: יוקקופמקי!"

#: dialog0327.txt:101
msgid "$0: Giń!"
msgstr "$0: תמות!"

#: dialog0327.txt:102
msgid "$1: Zaraz umrzesz!"
msgstr "$1: לגווע!"

#: dialog0327.txt:103
msgid "$2: Spróbuj tego!"
msgstr "$2: תאכל את זה!"

#: dialog0327.txt:104
msgid "$3: Yukkakoppamakki!"
msgstr "$3: יוקקופמקי!"

#: dialog0327.txt:100001
