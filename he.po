#: dialog0317.txt:1
msgid "OTHER: Zostaw mnie, ty wstrętna maszkaro!"
msgstr "OTHER: עזבי אותי לנפשי, חתיכת מפלצת מסריחה!"

#: dialog0318.txt:1
msgid "OTHER: Aaaaaaa!..."
msgstr "OTHER: אההההה!..."

#: dialog0319.txt:1
msgid "OTHER: Pomogłem ci już trzy razy. Teraz|muszę udać się w swoją stronę."
msgstr "OTHER: עזרתי לך שלושה פעמים. הגיע זמני לעזוב."

#: dialog0319.txt:2
msgid "OTHER: Spadam, pa!"
msgstr "OTHER: אני סיימתי, להתראות!"

#: dialog0320.txt:1
msgid "HERO: Niektórzy biorą pewne sprawy zbyt|dosłownie."
msgstr "HERO: יש אנשים שלוקחים דברים כפשוטם."

#: dialog0321.txt:1
msgid "OTHER: <mamrotanie>"
msgstr "OTHER: <מלמול>"

#: dialog0322.txt:1
msgid "OTHER: <szept>"
msgstr "OTHER: <לחישה>"

#: dialog0323.txt:1
msgid "HERO: Pani mąż coś zgubił..."
msgstr "HERO: בעלך איבד משהו..."

#: dialog0324.txt:1
msgid "HERO: Rozmową go chyba nie przestraszę..."
msgstr "HERO: אני לא חושב שדיבורים יפחידו אותו..."

#: dialog0325.txt:101
