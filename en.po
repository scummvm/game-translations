msgid ""
"Mit der Schaufelspitze alleine,\n"
"habe ich zu wenig Wucht..."
msgstr ""

msgctxt "object:17:0"
msgid ""
"Ein stabiler Holz-\n"
"pfahl, der an einem\n"
"Ende angespitzt ist."
msgstr ""

msgctxt "object:17:3"
msgid ""
"Damit kann ich doch das Ding\n"
"nicht zerkleinern."
msgstr ""

msgctxt "object:17:5"
