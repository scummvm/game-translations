msgstr ""

msgctxt "object:4:0"
msgid ""
"Eine Schnapsflasche mit\n"
"einem Hanfseil umwickelt."
msgstr ""

msgctxt "object:4:2"
msgid ""
"Ja, sobald die Flasche leer\n"
"ist, kann ich daraus einen\n"
"Kerzenständer machen."
msgstr ""

msgctxt "object:4:5"
msgid ""
"Was soll ich machen? Die Socken\n"
"mit dem Alkohol desinfizieren?"
msgstr ""

msgctxt "object:5:0"
msgid ""
"Eine Schnapsflasche."
msgstr ""

msgctxt "object:5:1"
msgid ""
"Ja, sobald die Flasche leer\n"
"ist, kann ich damit einen\n"
"Kerzenständer machen."
msgstr ""

msgctxt "object:5:4"
msgid ""
"Was soll ich machen? Die Socken\n"
"mit dem Alkohol desinfizieren?"
msgstr ""

msgctxt "object:6:0"
msgid ""
"Dieser Tramp scheint\n"
"gelangweilt zu sein."
msgstr ""

msgctxt "object:6:2"
msgid ""
"Hallo, Fremder..."
msgstr ""

msgctxt "object:6:3"
msgid ""
"Halt! Siehst Du\n"
"nicht, das Du\n"
"störst?"
msgstr ""

msgctxt "object:6:6"
msgid ""
"Der scheint mir für\n"
"Gespräche nicht auf-\n"
"gelegt zu sein."
msgstr ""

msgctxt "object:7:0"
msgid ""
"Eine Spitzhacke, die aus\n"
"dem Stiel der Schaufel\n"
"gemacht wurde."
msgstr ""

msgctxt "object:8:0"
msgid ""
"Eine angerostete\n"
"Hackenspitze."
msgstr ""

msgctxt "object:9:0"
msgid ""
"Sobald ich die Kerze dem\n"
"Wind aussetze, wird Sie\n"
"erlöschen."
msgstr ""

msgctxt "object:10:0"
msgid ""
"Die Kerze habe ich aus\n"
"der abmontierten Lampe."
msgstr ""

msgctxt "object:11:0"
msgid ""
"Vier Kerzen aus dem\n"
"Leuchter, den wir\n"
"abmontiert haben."
msgstr ""

msgctxt "object:11:3"
msgid ""
"Wenn die Kerze brennen würde, so\n"
"könnte man das Schwarzpulver gut\n"
"damit anzünden."
msgstr ""

msgctxt "object:11:6"
msgid ""
"Wenn ich die so anzünde, dann sind\n"
"die Kerzen beim kleinsten Windstoss\n"
"erloschen."
msgstr ""

msgctxt "object:13:0"
msgid ""
"Ein Korkenzieher, richtig\n"
"schade, dass keine Wein-\n"
"flasche zur Hand ist."
msgstr ""

msgctxt "object:14:0"
msgid ""
"Eine Lampe, die aus\n"
"einem alten Wagenrad\n"
"hergestellt wurde."
msgstr ""

msgctxt "object:14:3"
msgid ""
"Damit kann ich doch das Ding\n"
"nicht zerkleinern."
msgstr ""

msgctxt "object:14:5"
msgid ""
"Oh, jetzt soll ich wohl mit\n"
"roher Gewalt dahinter. Ich\n"
"bezweifle, dass dies eine gute\n"
"Idee ist. Lass uns etwas an-\n"
"deres zum Einheizen suchen."
msgstr ""

msgctxt "object:14:10"
msgid ""
"Damit habe ich zu wenig Wucht."
msgstr ""

msgctxt "object:14:11"
msgid ""
"Tja, damit könnte man mit viel\n"
"Gewalt das Ding zerkleinern, doch\n"
"ich bin mir nicht sicher, ob das\n"
"gut wäre. Wir sollten etwas ande-\n"
"res zum Einheizen suchen..."
msgstr ""

msgctxt "object:14:16"
msgid ""
"Mit der Schaufelspitze alleine,\n"
"habe ich zu wenig Wucht..."
msgstr ""

msgctxt "object:15:0"
msgid ""
"Die Tramps führen\n"
"was im Schilde!\n"
"Was die wohl wieder\n"
"planen???"
msgstr ""

msgctxt "object:15:4"
msgid ""
"Bei dem dubiosen\n"
"Gespräch, sollte man\n"
"die beiden lieber\n"
"nicht stören."
msgstr ""

msgctxt "object:16:0"
msgid ""
"Eine Lampe, die aus\n"
"einem alten Wagenrad\n"
"hergestellt wurde."
msgstr ""

msgctxt "object:16:3"
msgid ""
